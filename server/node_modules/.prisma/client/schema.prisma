generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Initial placeholder models for auth migration.
// Extend this schema using your Supabase tables from MYSQL_MIGRATION_CHECKLIST.md.
model User {
  id                 String                  @id @default(cuid())
  email              String                  @unique
  passwordHash       String                  @map("password_hash")
  fullName           String                  @map("full_name")
  role               String                  @default("agent")
  isActive           Boolean                 @default(true) @map("is_active")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  profile            UserProfile?
  companyAccesses    UserCompanyAccess[]
  warehouseAccesses  UserWarehouseAccess[]
  featurePermissions UserFeaturePermission[]

  @@map("users")
}

model Company {
  id                  String               @id @default(cuid())
  name                String
  address             String?              @db.Text
  contactNumber       String?              @map("contact_number")
  email               String?
  logoUrl             String?              @map("logo_url")
  isHeadquarters      Boolean              @default(false) @map("is_headquarters")
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  profiles            UserProfile[]
  companyAccesses     UserCompanyAccess[]
  warehouses          Warehouse[]
  categories          Category[]
  suppliers           Supplier[]
  transactionSettings TransactionSetting[]

  @@map("companies")
}

model Category {
  id          String   @id @default(cuid())
  companyId   String?  @map("company_id")
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  company     Company? @relation(fields: [companyId], references: [id])

  @@map("categories")
}

model Supplier {
  id            String   @id @default(cuid())
  companyId     String?  @map("company_id")
  name          String
  contactPerson String?  @map("contact_person")
  email         String?
  phone         String?
  address       String?  @db.Text
  city          String?
  notes         String?  @db.Text
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  company       Company? @relation(fields: [companyId], references: [id])

  @@map("suppliers")
}

model Unit {
  id           String   @id @default(cuid())
  name         String
  abbreviation String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("units")
}

model Bank {
  id            String   @id @default(cuid())
  bankName      String   @map("bank_name")
  currentAmount Decimal  @default(0) @map("current_amount") @db.Decimal(18, 2)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("banks")
}

model TransactionSetting {
  id             String   @id @default(cuid())
  companyId      String   @map("company_id")
  prefix         String   @default("ADDR")
  currentCounter Int      @default(700) @map("current_counter")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  company        Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId])
  @@map("transaction_settings")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  companyId String   @map("company_id")
  email     String
  fullName  String   @map("full_name")
  role      String   @default("agent")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id])

  @@map("user_profiles")
}

model UserCompanyAccess {
  id        String  @id @default(cuid())
  userId    String  @map("user_id")
  companyId String  @map("company_id")
  role      String  @default("agent")
  user      User    @relation(fields: [userId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
  @@map("user_company_access")
}

model UserWarehouseAccess {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  warehouseId String    @map("warehouse_id")
  user        User      @relation(fields: [userId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([userId, warehouseId])
  @@map("user_warehouse_access")
}

model Warehouse {
  id           String                @id @default(cuid())
  name         String
  companyId    String                @map("company_id")
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  company      Company               @relation(fields: [companyId], references: [id])
  userAccesses UserWarehouseAccess[]

  @@map("warehouses")
}

model UserFeaturePermission {
  id         String  @id @default(cuid())
  userId     String  @map("user_id")
  featureKey String  @map("feature_key")
  canView    Boolean @default(true) @map("can_view")
  canCreate  Boolean @default(true) @map("can_create")
  canEdit    Boolean @default(true) @map("can_edit")
  canDelete  Boolean @default(true) @map("can_delete")
  user       User    @relation(fields: [userId], references: [id])

  @@unique([userId, featureKey])
  @@map("user_feature_permissions")
}
